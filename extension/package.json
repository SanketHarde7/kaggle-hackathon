{
  "name": "stackdecide",
  "displayName": "StackDecide",
  "description": "AI-powered tech stack decision tool",
  "publisher": "klarityai",
  "version": "1.1.1",
  "icon": "image.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanketHarde7/kaggle-hackathon.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "stackdecide-sidebar",
          "title": "StackDecide",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "stackdecide-sidebar": [
        {
          "type": "webview",
          "id": "stackdecide.sidebarView",
          "name": "Launcher"
        }
      ]
    },
    "commands": [
      {
        "command": "stackdecide.analyze",
        "title": "StackDecide: Analyze Decision"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.0.4"
  }
}